# Database
DATABASE_URL=postgresql+asyncpg://aicms:aicms_password@postgres:5432/aicms
POSTGRES_USER=aicms
POSTGRES_PASSWORD=aicms_password
POSTGRES_DB=aicms

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# Application
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
DOMAIN=aicms.docmet.systems

# Email (SMTP)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@mystorey.io
SMTP_TLS=false

# Storage (media uploads)
# Use "local" for dev (files in Docker volume), "r2" for production
STORAGE_BACKEND=local
LOCAL_UPLOAD_PATH=/app/uploads
UPLOAD_BASE_URL=http://localhost/uploads
MAX_UPLOAD_SIZE_MB=10
# Cloudflare R2 (production only — leave blank for local dev)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# Development
NODE_ENV=development
PYTHONUNBUFFERED=1
