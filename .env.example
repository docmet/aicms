# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here

# ── JWT (generate with: openssl rand -hex 32) ─────────────────────────────────
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── Application URLs ──────────────────────────────────────────────────────────
DOMAIN=aicms.example.com
FRONTEND_URL=https://aicms.example.com
BACKEND_URL=https://aicms.example.com
NEXT_PUBLIC_API_URL=/api
# Public app URL used by MCP server to generate preview links for Claude
APP_URL=https://aicms.example.com

# ── Revolut Merchant (billing) ─────────────────────────────────────────────────
# Get from: Revolut Business → Merchant → API keys
REVOLUT_MERCHANT_API_KEY=
REVOLUT_WEBHOOK_SECRET=
REVOLUT_SANDBOX=true
