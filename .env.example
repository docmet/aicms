# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here

# ── JWT (generate with: openssl rand -hex 32) ─────────────────────────────────
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── Application URLs ──────────────────────────────────────────────────────────
DOMAIN=aicms.example.com
FRONTEND_URL=https://aicms.example.com
BACKEND_URL=https://aicms.example.com
NEXT_PUBLIC_API_URL=/api
# Public app URL used by MCP server to generate preview links for Claude
APP_URL=https://aicms.example.com

# ── Stripe (billing) ──────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Get from: Stripe Dashboard → Developers → Webhooks → endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Get from: Stripe Dashboard → Products → Price IDs
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Local dev: Mailpit runs at localhost:1025 (web UI at localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@mystorey.io
